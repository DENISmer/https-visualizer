# Supabase (Settings → API). Use service_role only on the server — never in the browser.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional. Comma-separated browser origins allowed to call the API (git push Pages, local Vite, etc.).
# If unset and NODE_ENV=production, defaults to https://httpsvisualizer.org (+ www).
# CORS_ALLOWED_ORIGINS=https://httpsvisualizer.org,https://www.httpsvisualizer.org,http://localhost:5173
